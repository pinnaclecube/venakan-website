# Careers integration — set these in Vercel (Project → Settings → Environment
# Variables) and in a local, gitignored .env. Never commit real values.
# All three are SERVER-SIDE ONLY — they must never reach the browser bundle.

# Zinterview API key — raw value, NO "Bearer " prefix. NOTE: the Careers apply
# flow no longer uses Zinterview (applications are stored in Supabase + emailed).
# Only the legacy, now-unused api/openings.ts still references this.
ZINTERVIEW_API_KEY=

# ── Careers applications (api/apply.ts) ──
# Résumés upload to the private Supabase "resumes" bucket and rows go to the
# "applications" table (reusing SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY).

# Where the new-application email (résumé attached) is delivered. Optional: if
# unset (or RESEND_API_KEY is unset), the application is still saved and a 200 is
# returned — the email is best-effort.
CAREERS_NOTIFY_EMAIL=

# From address for the application email (must be a Resend-verified sender).
# Defaults to "Venakan Careers <onboarding@resend.dev>" if unset.
CAREERS_FROM_EMAIL=

# Supabase project URL (safe inside serverless functions).
SUPABASE_URL=

# Supabase service role key — SERVER-SIDE ONLY. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic API key — SERVER-SIDE ONLY. Generates witty JD copy that is cached in
# Supabase (once per opening version), so it is never used from the browser.
ANTHROPIC_API_KEY=

# ── Training-interest registration (api/training-interest.ts) ──
# All SERVER-SIDE ONLY. Reuses SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY above for
# the training_* tables and the private "training-resumes" storage bucket.

# Resend API key — sends the new-registration alert email. Optional: if unset,
# the registration is still saved and a 200 is returned (email is best-effort).
RESEND_API_KEY=

# Where the training-interest alert email is delivered.
TRAINING_NOTIFY_EMAIL=

# From address for the alert (must be a Resend-verified sender/domain).
# Defaults to "Venakan <onboarding@resend.dev>" if unset.
TRAINING_FROM_EMAIL=

# ── Training admin (api/admin/*.ts) ──
# Shared admin password. SERVER-SIDE ONLY — sent by the admin UI in the
# x-admin-key header and compared with crypto.timingSafeEqual. Never in the
# client bundle. The admin spec generator reuses ANTHROPIC_API_KEY above, and
# generated/uploaded PDFs go to the public Supabase "training-specs" bucket.
ADMIN_PASSWORD=
